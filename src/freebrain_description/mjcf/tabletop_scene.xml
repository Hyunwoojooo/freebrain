<mujoco model="tabletop_scene">
  <!-- Robot model (compiler, option, defaults, assets, worldbody, actuators, sensors, contacts, equality) -->
  <include file="open_manipulator_x.xml"/>

  <!-- Scene-specific assets -->
  <asset>
    <texture name="grid_tex" type="2d" builtin="checker"
             rgb1="0.85 0.85 0.85" rgb2="0.7 0.7 0.7" width="64" height="64"/>
    <material name="grid_mat" texture="grid_tex" texrepeat="10 10"/>
    <material name="table_wood" rgba="0.55 0.37 0.2 1"/>
    <material name="blue_obj" rgba="0.2 0.6 0.8 1"/>
    <material name="green_obj" rgba="0.2 0.8 0.3 1"/>
    <material name="orange_obj" rgba="0.9 0.5 0.1 1"/>
  </asset>

  <worldbody>
    <light pos="0.3 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8" specular="0.3 0.3 0.3"/>
    <geom name="floor" type="plane" size="1 1 0.01" material="grid_mat"/>

    <!-- Table: 0.5 x 0.6 x 0.3 m (from rl_table.sdf) -->
    <body name="table" pos="0.3 0 0.15">
      <geom type="box" size="0.25 0.3 0.15" material="table_wood"
            condim="4" friction="1.0 0.005 0.0001"/>
    </body>

    <!-- Cube: 0.04m side, 50g (from rl_table.sdf) -->
    <body name="cube" pos="0.25 0 0.32">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="box" size="0.02 0.02 0.02"
            material="blue_obj" mass="0.05"
            condim="4" friction="1.0 0.005 0.0001"/>
    </body>

    <!-- Cylinder: r=0.02, h=0.06, 40g -->
    <body name="cylinder_obj" pos="0.28 0.08 0.33">
      <freejoint name="cylinder_free"/>
      <geom name="cylinder_geom" type="cylinder" size="0.02 0.03"
            material="green_obj" mass="0.04"
            condim="4" friction="1.0 0.005 0.0001"/>
    </body>

    <!-- Sphere: r=0.02, 30g -->
    <body name="sphere_obj" pos="0.28 -0.08 0.32">
      <freejoint name="sphere_free"/>
      <geom name="sphere_geom" type="sphere" size="0.02"
            material="orange_obj" mass="0.03"
            condim="4" friction="1.0 0.005 0.0001"/>
    </body>

    <!-- Overhead camera (from rl_env: pos=0.3,0,1.0, fov=60deg) -->
    <camera name="overhead" pos="0.3 0 1.0" fovy="60"/>

    <!-- Front-angled camera for visualization -->
    <camera name="front" pos="0.7 0 0.5" xyaxes="0 1 0 -0.55 0 0.85"/>
  </worldbody>

  <!-- Object position sensors (for RL observation) -->
  <sensor>
    <framepos name="cube_pos_sens" objtype="body" objname="cube"/>
    <framepos name="cylinder_pos_sens" objtype="body" objname="cylinder_obj"/>
    <framepos name="sphere_pos_sens" objtype="body" objname="sphere_obj"/>
  </sensor>
</mujoco>
